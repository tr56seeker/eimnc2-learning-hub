{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "disableAutoMode": "disable",
  "disableRemoteControl": true,
  "disableClaudeAiConnectors": true,
  "disableArtifact": true,
  "disableSkillShellExecution": true,
  "enableAllProjectMcpServers": false,

  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",

    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git stash *)",

      "PowerShell(npm install)",
      "PowerShell(npm ci)",
      "PowerShell(npm run *)",
      "PowerShell(npx *)",
      "PowerShell(git status)",
      "PowerShell(git diff *)",
      "PowerShell(git log *)",
      "PowerShell(git add *)",
      "PowerShell(git commit *)",
      "PowerShell(git checkout *)",
      "PowerShell(git branch *)",
      "PowerShell(git stash *)"
    ],

    "ask": [
      "Edit(./lib/supabase/**)",
      "Edit(./app/api/**)",
      "Edit(./supabase/migrations/**)",
      "Edit(./middleware.ts)",
      "Edit(./proxy.ts)",

      "Bash(git push *)",
      "Bash(supabase *)",
      "Bash(vercel *)",
      "PowerShell(git push *)",
      "PowerShell(supabase *)",
      "PowerShell(vercel *)"
    ],

    "deny": [
      "mcp__*",

      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "PowerShell(Remove-Item -Recurse -Force *)",
      "PowerShell(Invoke-WebRequest *)",
      "PowerShell(iwr *)",
      "PowerShell(git push --force*)",
      "PowerShell(git push -f*)",

      "WebFetch(domain:*.supabase.co)",
      "WebFetch(domain:api.vercel.com)",
      "WebFetch(domain:api.cloudflare.com)",
      "WebFetch(domain:eimnc2.tabunocnatlhs.com)",

      "Read(.env)",
      "Read(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",

      "Read(./.vercel/**)",
      "Edit(./.vercel/**)",
      "Read(./secrets/**)",
      "Edit(./secrets/**)",
      "Read(./private-data/**)",
      "Edit(./private-data/**)",
      "Read(./data/private/**)",
      "Edit(./data/private/**)",
      "Read(./storage/private/**)",
      "Edit(./storage/private/**)",
      "Read(./backups/**)",
      "Edit(./backups/**)",
      "Read(./exports/**)",
      "Edit(./exports/**)",
      "Read(./logs/**)",
      "Edit(./logs/**)",
      "Read(./uploads/**)",
      "Edit(./uploads/**)",
      "Read(./public/uploads/**)",
      "Edit(./public/uploads/**)",
      "Read(./public/learner-photos/**)",
      "Edit(./public/learner-photos/**)",
      "Read(./public/id-photos/**)",
      "Edit(./public/id-photos/**)",
      "Read(./supabase/.temp/**)",
      "Edit(./supabase/.temp/**)",
      "Read(./supabase/seed.sql)",
      "Edit(./supabase/seed.sql)",

      "Read(**/*.db)",
      "Edit(**/*.db)",
      "Read(**/*.sqlite)",
      "Edit(**/*.sqlite)",
      "Read(**/*.sqlite3)",
      "Edit(**/*.sqlite3)",
      "Read(**/*.bak)",
      "Edit(**/*.bak)",
      "Read(**/*.pem)",
      "Edit(**/*.pem)",
      "Read(**/*.key)",
      "Edit(**/*.key)",
      "Read(**/*.p12)",
      "Edit(**/*.p12)",
      "Read(**/*.pfx)",
      "Edit(**/*.pfx)",
      "Read(**/service-account*.json)",
      "Edit(**/service-account*.json)",
      "Read(**/credentials*.json)",
      "Edit(**/credentials*.json)",
      "Read(**/client_secret*.json)",
      "Edit(**/client_secret*.json)",
      "Read(**/firebase-admin*.json)",
      "Edit(**/firebase-admin*.json)",
      "Read(**/auth-users*.json)",
      "Edit(**/auth-users*.json)",
      "Read(**/*dump*.sql)",
      "Edit(**/*dump*.sql)",
      "Read(**/*backup*.sql)",
      "Edit(**/*backup*.sql)",
      "Read(**/*export*.sql)",
      "Edit(**/*export*.sql)",

      "Edit(./.claude/**)",
      "Edit(./.gitignore)",
      "Edit(./CLAUDE.md)",
      "Edit(./.mcp.json)"
    ]
  }
}